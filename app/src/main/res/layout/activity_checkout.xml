<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FCEF"
    android:animateLayoutChanges="true"
    tools:context=".ui.checkout.CheckoutActivity">

    <!-- Top App Bar -->
    <RelativeLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_category_circle"
            android:padding="8dp"
            app:tint="#161D16"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Checkout"
            android:textSize="18sp"
            android:textColor="#006E2B"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        android:clipToPadding="false"
        android:paddingBottom="24dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Delivery Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delivery Address"
                android:textSize="18sp"
                android:textColor="#161D16"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_dialog_map"
                        app:tint="#1AB64F"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Home"
                            android:textColor="#161D16"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="242 Gardens Ave, Apt 4B\nGreen Park, NY 10012"
                            android:textColor="#6D7B6B"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delivery Instruction: Leave at the front door."
                            android:textColor="#6D7B6B"
                            android:textSize="12sp"
                            android:textStyle="italic"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Payment Method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textSize="18sp"
                android:textColor="#161D16"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <RadioGroup
                    android:id="@+id/rgPayment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp">

                    <RadioButton
                        android:id="@+id/rbCOD"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Cash on Delivery"
                        android:textColor="#161D16"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:buttonTint="#1AB64F"
                        android:checked="true"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F4FCEF"
                        android:layout_marginHorizontal="16dp"/>

                    <RadioButton
                        android:id="@+id/rbUPI"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="UPI (Google Pay/PhonePe)"
                        android:textColor="#161D16"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:buttonTint="#1AB64F"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F4FCEF"
                        android:layout_marginHorizontal="16dp"/>

                    <RadioButton
                        android:id="@+id/rbCard"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Credit/Debit Card"
                        android:textColor="#161D16"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="16dp"
                        android:buttonTint="#1AB64F"/>
                </RadioGroup>
            </com.google.android.material.card.MaterialCardView>
            
            <!-- Order Summary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Summary"
                android:textSize="18sp"
                android:textColor="#161D16"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:layout_marginTop="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"
                android:layout_marginTop="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvCheckoutItemsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Items Total"
                        android:textColor="#6D7B6B"
                        android:textSize="14sp"/>
                    <TextView
                        android:id="@+id/tvCheckoutSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="$0.00"
                        android:textColor="#161D16"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivery Fee"
                        android:textColor="#6D7B6B"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="FREE"
                        android:textColor="#1AB64F"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"/>
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_nav"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="16dp">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlaceOrder"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Place Order →"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            app:cornerRadius="999dp"
            app:backgroundTint="#1AB64F"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
