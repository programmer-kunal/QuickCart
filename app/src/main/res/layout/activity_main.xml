<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4FCEF"
    tools:context=".MainActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Top Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home - 123, GreenPark"
                        android:textColor="#161D16"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivering in 15 mins"
                        android:textColor="#1AB64F"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_category_circle"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#161D16" />
            </RelativeLayout>

            <!-- Search Bar -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_search_input"
                android:hint="Search for groceries..."
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="12dp"
                android:textColor="#161D16"
                android:textColorHint="#6D7B6B"
                android:inputType="text"
                android:elevation="0dp" />

            <!-- Promotional Banner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#006E2B"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_promo_banner" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#B3006E2B" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Get 50% OFF\non your first order"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-medium"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginTop="12dp"
                            android:text="Order Now"
                            android:textColor="#006E2B"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium"
                            android:textAllCaps="false"
                            app:cornerRadius="999dp"
                            app:backgroundTint="#FFD700"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Categories Section -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- All -->
                    <LinearLayout
                        android:id="@+id/llCatAll"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivCatAll"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_category_circle"
                            android:backgroundTint="#1AB64F"
                            android:padding="14dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            app:tint="#FFFFFF"/>
                        <TextView
                            android:id="@+id/tvCatAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All"
                            android:textSize="11sp"
                            android:textColor="#1AB64F"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>

                    <!-- Fruits -->
                    <LinearLayout
                        android:id="@+id/llCatFruits"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivCatFruits"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_category_circle"
                            android:padding="12dp"
                            android:src="@drawable/ic_category_fruits"
                            app:tint="#006E2B"/>
                        <TextView
                            android:id="@+id/tvCatFruits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fruits"
                            android:textSize="11sp"
                            android:textColor="#161D16"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>

                    <!-- Vegetables -->
                    <LinearLayout
                        android:id="@+id/llCatVeg"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivCatVeg"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_category_circle"
                            android:padding="12dp"
                            android:src="@drawable/ic_category_vegetables"
                            app:tint="#006E2B"/>
                        <TextView
                            android:id="@+id/tvCatVeg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Veg"
                            android:textSize="11sp"
                            android:textColor="#161D16"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>

                    <!-- Dairy -->
                    <LinearLayout
                        android:id="@+id/llCatDairy"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivCatDairy"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_category_circle"
                            android:padding="12dp"
                            android:src="@drawable/ic_category_dairy"
                            app:tint="#006E2B"/>
                        <TextView
                            android:id="@+id/tvCatDairy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dairy"
                            android:textSize="11sp"
                            android:textColor="#161D16"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>

                    <!-- Snacks -->
                    <LinearLayout
                        android:id="@+id/llCatSnacks"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivCatSnacks"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_category_circle"
                            android:padding="12dp"
                            android:src="@drawable/ic_category_snacks"
                            app:tint="#006E2B"/>
                        <TextView
                            android:id="@+id/tvCatSnacks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Snacks"
                            android:textSize="11sp"
                            android:textColor="#161D16"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>

                    <!-- Beverages -->
                    <LinearLayout
                        android:id="@+id/llCatDrinks"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivCatDrinks"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_category_circle"
                            android:padding="12dp"
                            android:src="@drawable/ic_category_drinks"
                            app:tint="#006E2B"/>
                        <TextView
                            android:id="@+id/tvCatDrinks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drinks"
                            android:textSize="11sp"
                            android:textColor="#161D16"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Product Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fresh for You"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="#161D16"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"/>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:listitem="@layout/item_product" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:elevation="16dp"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                app:tint="#1AB64F"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="#1AB64F"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_categories"
                app:tint="#6D7B6B"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categories"
                android:textSize="11sp"
                android:textColor="#6D7B6B"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/btnNavCart"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_cart"
                app:tint="#6D7B6B"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cart"
                android:textSize="11sp"
                android:textColor="#6D7B6B"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_profile"
                app:tint="#6D7B6B"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="#6D7B6B"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>