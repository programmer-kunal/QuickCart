<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNavigationContainer"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="16dp"
    android:clickable="true"
    android:focusable="true"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp">

    <!-- Home Tab -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/ivNavHome"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_home"
            app:tint="#6D7B6B"/>
        <TextView
            android:id="@+id/tvNavHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="11sp"
            android:textColor="#6D7B6B"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- Categories Tab -->
    <LinearLayout
        android:id="@+id/navCategories"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/ivNavCategories"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_categories"
            app:tint="#6D7B6B"/>
        <TextView
            android:id="@+id/tvNavCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categories"
            android:textSize="11sp"
            android:textColor="#6D7B6B"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- Cart Tab -->
    <LinearLayout
        android:id="@+id/navCart"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/ivNavCart"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_cart"
            app:tint="#6D7B6B"/>
        <TextView
            android:id="@+id/tvNavCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cart"
            android:textSize="11sp"
            android:textColor="#6D7B6B"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- Profile Tab -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless">
        <ImageView
            android:id="@+id/ivNavProfile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_profile"
            app:tint="#6D7B6B"/>
        <TextView
            android:id="@+id/tvNavProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="11sp"
            android:textColor="#6D7B6B"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

</LinearLayout>
